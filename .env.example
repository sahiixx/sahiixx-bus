# --- SAHIIXX Ecosystem Environment Variables -------------------------------------
# Copy to .env and fill in your values:  cp .env.example .env
# Never commit .env to git.

# -- GitHub -------------------------------------------------------------------
GITHUB_TOKEN=ghp_your_token_here
GITHUB_USER=sahiixx

# -- AI Models ----------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here          # optional, fallback model

# -- Bus ----------------------------------------------------------------------
SAHIIXX_BUS_HOST=0.0.0.0
SAHIIXX_BUS_PORT=8000
SAHIIXX_BUS_MCP_PORT=8001
SAHIIXX_BUS_NAMESPACE=sahiixx

# -- Neo4j (graph-sight + geoflow) --------------------------------------------
NEO4J_PASSWORD=your_strong_password_here
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j

# -- Redis (AGI layer) --------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -- Qdrant (vector store) ----------------------------------------------------
QDRANT_URL=http://qdrant:6333

# -- Friday OS (voice) --------------------------------------------------------
LIVEKIT_URL=wss://your-livekit-cloud-url
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# -- SaaS Platform ------------------------------------------------------------
SECRET_KEY=generate-with-openssl-rand-hex-32

# -- Telegram (sovereign-swarm notifications) ---------------------------------
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# -- Optional: Ollama (local LLM for clearwing) -------------------------------
OLLAMA_BASE_URL=http://localhost:11434
